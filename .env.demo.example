# Demo database — copy this file to .env.demo and fill in the URL.
# Keep .env.demo out of version control (it's in .gitignore).
#
# Example (local Postgres):
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/landlord_demo
#
# Example (Supabase / Neon / Railway):
#   DATABASE_URL=postgresql://user:password@host:5432/landlord_demo
DATABASE_URL=postgresql://postgres:password@localhost:5432/landlord_demo
