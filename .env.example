# Copy this file to .env and set a strong password before running ./setup.sh
#
#   cp .env.example .env
#   # Edit POSTGRES_PASSWORD, then:
#   ./setup.sh

POSTGRES_USER=landlord
POSTGRES_PASSWORD=secret
POSTGRES_DB=landlord_dev
POSTGRES_PORT=5432

# Database connection — choose ONE of the options below:
#
# Option A: local dev (honcho/venv) — connects via localhost
# DATABASE_URL=postgresql://landlord:secret@localhost:5432/landlord_dev
#
# Option B: docker-compose — uses container name (works on Mac/Windows/Linux)
DATABASE_URL=postgresql://landlord:secret@landlord-pg:5432/landlord_dev
#
# Option C: Neon cloud (multi-machine) — works in both modes
# DATABASE_URL=postgresql://<user>:<pass>@<host>/neondb?sslmode=require&channel_binding=require

# JWT signing secret for the Next.js frontend (generate a random 32+ char string)
JWT_SECRET=

# Optional: encrypt SMTP password stored in the config table.
# Generate a key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Optional: app password gate (required before exposing beyond localhost).
# Generate a hash with:
#   python -c 'import bcrypt, getpass; print(bcrypt.hashpw(getpass.getpass().encode(), bcrypt.gensalt()).decode())'
APP_USERNAME=admin
APP_PASSWORD_HASH=

# Connection pool sizing (defaults: 1 / 10)
# DB_POOL_MIN=1
# DB_POOL_MAX=10
